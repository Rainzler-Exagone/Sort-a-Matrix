 #include <stdio.h>


void tri_sel(int *tab, int max)
{
 int ind_min,i,j;
     int temp;
     i=0;
   while(i<max)
   {
   	ind_min=i;
   	 for(j=i+1;j<max;j++)
   	 {
   	 	if(tab[j]<tab[ind_min])
   	 	{
   	 		ind_min=j;
   	 	}
   	 }
   	temp=tab[i];
   	 tab[i]=tab[ind_min];
   	 tab[ind_min]-temp;
   	 i=i+1;
   }
	}
	
int main()
{
	int i;
	int matrix[3][3]={{1,2,3},{5,7,9},{6,8,9}};
	int array[9];
	int max=9;
	//transforme the values of the matrix in the array
	 for(i=0;i<9;i++)
	 {
	  array[i]=matrix[i/3][i%3];
	 }
	//Display the arr
	   for(i=0;i<9;i++)
	   {
	   	printf("array[%d]=%d \n",i,array[i]);
	   	
	   }
	   printf("\n");
	   for(i=0;i<9;i++)
	   {
	   tri_sel( array,max);
	   printf("array[%d]=%d\n",i,array[i]);
	   }
	   return 0;
           // Rainzler 
	}
